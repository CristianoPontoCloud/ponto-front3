# ===========================================
# PontoCloud Client-Side - Variáveis de ambiente
# ===========================================
# Copie para .env.local e preencha os valores.
# Para deploy na Vercel: configure em Project Settings > Environment Variables.
# ===========================================

# --- NextAuth ---
NEXTAUTH_URL=https://app.dev.ponto.cloud
NEXTAUTH_SECRET=

# --- API Backend (BFF) ---
# Base URL deve incluir /api/v1 pois o BFF expõe as rotas sob esse prefixo (ex.: /api/v1/enrollment/email)
NEXT_PUBLIC_API_BASE_URL=https://bff.app.dev.ponto.cloud/api/v1
NEXT_PUBLIC_API_LOCAL=

# --- Imagens ---
NEXT_PUBLIC_IMG_PROTOCOL=https
NEXT_PUBLIC_LOCALHOST=img.app.dev.ponto.cloud
NEXT_PUBLIC_IMG_PORT=
NEXT_PUBLIC_IMG_PATH=/api/
NEXT_PUBLIC_IMG_FULL_URL=https://img.app.dev.ponto.cloud/api/

# --- Criptografia/Sistema ---
NEXT_PUBLIC_SYS_CONFIG_SECRET=

# --- Google Maps ---
NEXT_PUBLIC_MAPS_KEY=
NEXT_PUBLIC_MAPS_ID=
NEXT_PUBLIC_MAPS_GEOCODE_API=

# --- Pusher (notificações em tempo real) ---
NEXT_PUBLIC_PUSHER_APP_ID=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_USE_TLS=true

# --- WebSocket ---
NEXT_PUBLIC_API_WEB_SOCKET=wss://bff.app.dev.ponto.cloud
NEXT_PUBLIC_WEB_SOCKET_PATH=/socket.io
